{
  "name": "restaurant-app-mvp",
  "version": "1.0.0",
  "description": "Restaurant PWA App MVP - Customer, Waiter, and Admin interfaces",
  "overrides": {
    "typescript": "5.9.3",
    "@prisma/client": "5.21.0",
    "prisma": "5.21.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:pwa\" \"npm run dev:backend\"",
    "dev:pwa": "cd dark-culinary-pwa && npm run start",
    "dev:frontend": "cd frontend && npm run start",
    "dev:backend": "cd backend && npm run start:dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "setup:db": "cd scripts && node setup-database.js",
    "seed:db": "cd scripts && node seed-database.js",
    "fix:lodash": "npm install lodash@4.17.21 --save-dev --legacy-peer-deps"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.2",
    "@angular-devkit/core": "^17.3.17",
    "ajv": "^8.17.1",
    "concurrently": "^8.2.2",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "@angular/animations": "21.1.3",
    "@angular/cdk": "21.1.3",
    "@angular/cli": "^21.1.2",
    "@angular/common": "21.1.3",
    "@angular/compiler": "21.1.3",
    "@angular/compiler-cli": "21.1.3",
    "@angular/core": "21.1.3",
    "@angular/forms": "21.1.3",
    "@angular/material": "21.1.3",
    "@angular/platform-browser": "21.1.3",
    "@angular/platform-browser-dynamic": "21.1.3",
    "@angular/router": "21.1.3",
    "@angular/service-worker": "21.1.3",
    "@nestjs/cli": "^11.0.16",
    "rxjs": "7.8.1",
    "webpack": "^5.105.0"
  }
}